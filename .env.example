# ─────────────────────────────────────────────
# 認証 (NextAuth.js v5)
# ─────────────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials で取得
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# `openssl rand -base64 32` で生成
AUTH_SECRET=replace_with_a_long_random_string

# 本番では実際のドメインに変更
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────
# データベース (Prisma)
# ─────────────────────────────────────────────
# 開発: SQLite (file:./dev.db)
# Vercel デモ: SQLite を /tmp 配下に置く (ephemeral / cold start ごとに seed)
#   DATABASE_URL="file:/tmp/dev.db"
# 本番: PostgreSQL 推奨 (Supabase / Neon)
#   DATABASE_URL="postgres://user:pass@host/db?sslmode=require"
DATABASE_URL="file:./dev.db"

# ─────────────────────────────────────────────
# LINE Messaging API
# ─────────────────────────────────────────────
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# Google Chat
# ─────────────────────────────────────────────
GCHAT_WEBHOOK_URL=

# ─────────────────────────────────────────────
# 許可ドメイン (カンマ区切り)
# 例: gowa58.co.jp,digirise.ai
# ─────────────────────────────────────────────
ALLOWED_EMAIL_DOMAINS=gowa58.co.jp,digirise.ai

# ─────────────────────────────────────────────
# デモモード
# true にすると Google OAuth なしでもログイン可 / Webhook 署名検証スキップ
# Vercel デプロイ時 (お客様ご商談用) は両方 true にする。
# 本番運用に移すときは両方 false に切り替える。
# ─────────────────────────────────────────────
DEMO_MODE=true
# クライアント側 (DemoBanner / Topbar の「他のロールで試す」) で参照する公開フラグ。
# DEMO_MODE と必ず同じ値を入れる。
NEXT_PUBLIC_DEMO_MODE=true
